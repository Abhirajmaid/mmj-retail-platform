{
  "name": "jewellery-retail-platform",
  "private": true,
  "packageManager": "npm@10.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --filter=!@jewellery-retail/backend",
    "dev:all": "turbo run dev --filter=!@jewellery-retail/backend",
    "dev:storefront": "turbo run dev --filter=mmj-web",
    "dev:backend": "turbo run dev --filter=@jewellery-retail/backend",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.0",
    "turbo": "^2.0.0"
  },
  "dependencies": {
    "@iconify/react": "^6.0.2",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "overrides": {
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwindcss": "^3.4.0"
  }
}
