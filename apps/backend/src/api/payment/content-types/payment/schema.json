{
  "kind": "collectionType",
  "collectionName": "payments",
  "info": {
    "singularName": "payment",
    "pluralName": "payments",
    "displayName": "Payment",
    "description": "Payments recorded against sales"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "amount": {
      "type": "decimal",
      "required": true
    },
    "method": {
      "type": "enumeration",
      "enum": ["cash", "card", "upi", "bank", "cheque", "other"],
      "default": "cash"
    },
    "reference": {
      "type": "string"
    },
    "date": {
      "type": "datetime",
      "required": true
    },
    "sale": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::sale.sale",
      "inversedBy": "payments"
    }
  }
}
