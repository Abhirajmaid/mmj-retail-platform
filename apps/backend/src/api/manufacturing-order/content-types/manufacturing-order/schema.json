{
  "kind": "collectionType",
  "collectionName": "manufacturing_orders",
  "info": {
    "singularName": "manufacturing-order",
    "pluralName": "manufacturing-orders",
    "displayName": "Manufacturing Order",
    "description": "Jewellery manufacturing jobs assigned to karigars"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "design": {
      "type": "string"
    },
    "design_image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "issued_gold_weight": {
      "type": "decimal"
    },
    "stone_used": {
      "type": "decimal",
      "default": 0
    },
    "wastage": {
      "type": "decimal",
      "default": 0
    },
    "final_weight": {
      "type": "decimal"
    },
    "status": {
      "type": "enumeration",
      "enum": ["draft", "issued", "in-progress", "completed", "cancelled"],
      "default": "draft"
    },
    "issue_date": {
      "type": "date"
    },
    "expected_date": {
      "type": "date"
    },
    "completion_date": {
      "type": "date"
    },
    "notes": {
      "type": "text"
    },
    "karigar": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::karigar.karigar",
      "inversedBy": "manufacturing_orders"
    }
  }
}
