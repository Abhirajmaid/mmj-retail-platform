{
  "kind": "collectionType",
  "collectionName": "sales",
  "info": {
    "singularName": "sale",
    "pluralName": "sales",
    "displayName": "Sale",
    "description": "Sales transactions / invoices"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "invoice_number": {
      "type": "string",
      "unique": true
    },
    "date": {
      "type": "datetime",
      "required": true
    },
    "total_amount": {
      "type": "decimal",
      "default": 0
    },
    "gst_amount": {
      "type": "decimal",
      "default": 0
    },
    "discount": {
      "type": "decimal",
      "default": 0
    },
    "payment_status": {
      "type": "enumeration",
      "enum": ["pending", "partial", "paid", "cancelled"],
      "default": "pending"
    },
    "notes": {
      "type": "text"
    },
    "customer": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::customer.customer",
      "inversedBy": "sales"
    },
    "store": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::store.store",
      "inversedBy": "sales"
    },
    "sale_items": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::sale-item.sale-item",
      "mappedBy": "sale"
    },
    "payments": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::payment.payment",
      "mappedBy": "sale"
    }
  }
}
