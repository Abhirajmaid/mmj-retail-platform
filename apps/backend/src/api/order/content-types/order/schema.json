{
  "kind": "collectionType",
  "collectionName": "orders",
  "info": {
    "singularName": "order",
    "pluralName": "orders",
    "displayName": "Order",
    "description": "Customer purchase orders"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "orderNumber": {
      "type": "uid"
    },
    "status": {
      "type": "enumeration",
      "enum": ["pending", "paid", "shipped", "delivered", "cancelled"],
      "default": "pending"
    },
    "total": {
      "type": "decimal"
    },
    "paymentMethod": {
      "type": "string"
    },
    "items": {
      "type": "json"
    },
    "customer": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::customer.customer",
      "inversedBy": "orders"
    }
  }
}
