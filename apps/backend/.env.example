# ─── Server ──────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=1337
PUBLIC_URL=http://localhost:1337

# ─── App Keys (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
APP_KEYS=appKey1,appKey2
API_TOKEN_SALT=randomsalt
ADMIN_JWT_SECRET=adminJwtSecret
TRANSFER_TOKEN_SALT=transferTokenSalt

# ─── Authentication ───────────────────────────────────────────────────────────
JWT_SECRET=supersecret

# ─── Database (SQLite — default) ─────────────────────────────────────────────
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db
DATABASE_CONNECTION_TIMEOUT=60000

# ─── Database (PostgreSQL — swap DATABASE_CLIENT=postgres to use) ─────────────
# DATABASE_CLIENT=postgres
# DATABASE_HOST=127.0.0.1
# DATABASE_PORT=5432
# DATABASE_NAME=jewellery_retail
# DATABASE_USERNAME=strapi
# DATABASE_PASSWORD=strapi
# DATABASE_SSL=false

# ─── GraphQL ─────────────────────────────────────────────────────────────────
GRAPHQL_PLAYGROUND=false
