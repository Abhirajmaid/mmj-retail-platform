# Strapi backend URL (no trailing slash)
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337

# Strapi API token (generate in Strapi Admin → Settings → API Tokens)
STRAPI_API_TOKEN=your_strapi_api_token_here

# Store ID for this billing terminal (used for filtering)
NEXT_PUBLIC_STORE_ID=1

# Gold rates (can be overridden; normally fetched from API)
NEXT_PUBLIC_GOLD_RATE_24KT=6420
NEXT_PUBLIC_GOLD_RATE_22KT=5885
NEXT_PUBLIC_GOLD_RATE_18KT=4815
NEXT_PUBLIC_SILVER_RATE=82
